---
import info from '../data/info.json';
const { name, description } = info.restaurant;
---

<section id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <h2 class="section-title">Nossa História</h2>
        <hr class="section-divider" />
        <p>{description}</p>
        <p>
          Cada receita carrega memórias afetivas e técnicas aprimoradas ao longo dos anos.
          Aqui você não encontra pressa — só sabor, ambiente e boa conversa.
        </p>
      </div>
      <div class="about-image">
        <div class="about-image-placeholder">🍽️</div>
      </div>
    </div>
  </div>
</section>
