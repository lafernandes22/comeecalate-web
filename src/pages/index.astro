---
import Header from '../components/Header.astro';
import Menu from '../components/Menu.astro';
import About from '../components/About.astro';
import Gallery from '../components/Gallery.astro';
import Location from '../components/Location.astro';
import info from '../data/info.json';
import '../styles/global.css';

const { name, tagline } = info.restaurant;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${name} — ${tagline}`} />
    <title>{name}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />

    <section id="hero" class="hero">
      <div class="hero-bg"></div>
      <div class="hero-content">
        <img src="/logo.svg" alt={name} class="hero-logo" />
        <a href="#menu" class="btn">Ver Cardápio</a>
      </div>
    </section>

    <Menu />
    <About />
    <Gallery />
    <Location />

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} {name}. Todos os direitos reservados.</p>
    </footer>
  </body>
</html>
